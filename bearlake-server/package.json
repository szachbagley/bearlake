{
  "name": "bearlake-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Bear Lake cabin app API",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
