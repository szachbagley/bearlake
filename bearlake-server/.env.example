# Bear Lake API — environment configuration
# Copy to .env for local development. .env is gitignored and must never be committed.

NODE_ENV=development
PORT=3000

# Database. Railway supplies MYSQL_URL; locally either form works.
# For local development, `docker compose up -d` starts MySQL 8.4 on port 3308
# with both databases created. See docker-compose.yml.
MYSQL_URL=mysql://root:bearlake-local@127.0.0.1:3308/bearlake
# MYSQLHOST=127.0.0.1
# MYSQLPORT=3308
# MYSQLUSER=root
# MYSQLPASSWORD=bearlake-local
# MYSQLDATABASE=bearlake

# Database used by `npm test`. Dropped and re-migrated on every run — never
# point this at a database holding real data.
DB_NAME_TEST=bearlake_test

# Access-token signing key. At least 32 characters, random.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-me-with-at-least-32-random-characters

# Optional token lifetime overrides.
# ACCESS_TOKEN_TTL_MIN=30
# REFRESH_TOKEN_TTL_DAYS=60

# CORS allowlist for the web admin app, comma-separated. Empty in production
# only if the web app is served from the same origin as the API.
WEB_ORIGIN=http://localhost:5173

# S3 (private bucket, Block Public Access on) for knowledge base images.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_REGION=us-west-2
S3_BUCKET=bearlake-media
